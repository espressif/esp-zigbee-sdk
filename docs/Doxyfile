MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             =    \
    $(ENV_DOXYGEN_DEFINES)  \
    __attribute__(x)=       \
    EZB_DEPRECATED=         \
    EZB_EXPERIMENTAL=       \
    EZB_PACKED_BEGIN=       \
    EZB_PACKED_FIELD=       \
    EZB_PACKED_END=         \

## Do not complain about not having dot
##
HAVE_DOT = NO

## Generate XML that is required for Breathe
##
GENERATE_XML    = YES
XML_OUTPUT      = xml

GENERATE_HTML   = NO
GENERATE_LATEX  = NO
GENERATE_MAN    = YES
GENERATE_RTF    = NO

## Skip distracting progress messages
##
QUIET = YES

## Enable Section Tags for conditional documentation
##
ENABLED_SECTIONS += DOC_EXCLUDE_HEADER_SECTION
ENABLED_SECTIONS += DOC_SINGLE_GROUP
